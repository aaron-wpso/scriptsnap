# ── Supabase Database ──────────────────────────────────────────────────────────
# Use the SESSION POOLER string (port 5432) — NOT the transaction pooler (6543).
# EF Core uses prepared statements which break in transaction mode.
# In Supabase: Settings → Database → "Connect" button → "Session" tab → copy URI
# Format: postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
ConnectionStrings__DefaultConnection=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Supabase Auth ───────────────────────────────────────────────────────────────
# Just the project URL — JWT keys are fetched automatically from the JWKS endpoint
Supabase__Url=https://your-project.supabase.co

# ── AssemblyAI ──────────────────────────────────────────────────────────────────
AssemblyAI__ApiKey=your-assemblyai-api-key

# ── Telegram ────────────────────────────────────────────────────────────────────
Telegram__BotToken=your-telegram-bot-token
Telegram__WebhookUrl=https://your-api.railway.app  # Set after Railway deploys

# ── CORS ────────────────────────────────────────────────────────────────────────
AllowedOrigins__0=https://your-app.vercel.app      # Set after Vercel deploys
